# All environment variables are optional for the demo deployment.
# Do not add blank variables in Vercel; only add a key when you have a real value.

# Real persistence, for example Neon, Supabase, or Vercel Postgres.
DATABASE_URL=

# Real SMS delivery through Twilio.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Real WhatsApp delivery through WhatsApp Cloud API.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Optional AI-generated calming guidance. Without this, rule-based guidance is used.
OPENAI_API_KEY=
